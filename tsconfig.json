{
	"compilerOptions": {
		"outDir": ".millennium/Dist",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"ignoreDeprecations": "5.0",
		"target": "ES2020",
		"jsx": "react",
		"strict": false,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"skipLibCheck": true
	},
	"include": ["frontend/**/*"]
}
